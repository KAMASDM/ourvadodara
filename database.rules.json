{
  "rules": {
    // Public read for published content
    "posts": {
      ".read": true,
      ".indexOn": ["status"],
      "$postId": {
        ".write": "auth != null",
        "analytics": {
          ".read": true,
          ".write": true
        }
      }
    },
    
    "stories": {
      ".read": true,
      "$storyId": {
        ".write": "auth != null",
        "analytics": {
          ".read": true,
          ".write": true
        }
      }
    },
    
    "reels": {
      ".read": true,
      "$reelId": {
        ".write": "auth != null",
        "analytics": {
          ".read": true,
          ".write": true
        }
      }
    },
    
    "carousels": {
      ".read": true,
      "$carouselId": {
        ".write": "auth != null",
        "analytics": {
          ".read": true,
          ".write": true
        }
      }
    },
    
    // Comments - authenticated users can read and write
    "comments": {
      ".read": true,
      "$postId": {
        ".write": "auth != null && ((root.child('posts').child($postId).exists() && root.child('posts').child($postId).child('commentsEnabled').val() != false) || (root.child('reels').child($postId).exists() && root.child('reels').child($postId).child('commentsEnabled').val() != false && root.child('reels').child($postId).child('reelSettings').child('allowComments').val() != false) || (root.child('carousels').child($postId).exists() && (root.child('carousels').child($postId).child('commentsEnabled').val() == true || root.child('carousels').child($postId).child('carouselSettings').child('allowComments').val() == true)) || root.child('polls').child($postId).exists())"
      }
    },
    
    // Users - users can read their own data and admins can read all
    "users": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        "role": {
          ".validate": "root.child('users').child(auth.uid).child('role').val() === 'admin' || (data.exists() && newData.val() === data.val()) || (!data.exists() && newData.val() === 'user')"
        },
        "brandId": {
          ".validate": "root.child('users').child(auth.uid).child('role').val() === 'admin' || (data.exists() && newData.val() === data.val())"
        }
      }
    },
    
    // Notifications - users can read their own notifications
    "notifications": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null"
      }
    },

    // FCM push tokens - each user reads/writes only their own token. Without
    // this rule the client's token write was denied, so push registration
    // failed silently.
    "fcmTokens": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    
    // App settings - public read (frontend may need config), admin write
    "settings": {
      ".read": true,
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },

    // Categories - public read, admin write
    "categories": {
      ".read": true,
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },
    
    // Cities - public read, admin write
    "cities": {
      ".read": true,
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },
    
    // Cities Config - public read, admin write
    "cities-config": {
      ".read": true,
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },
    
    // Events - public read, authenticated write
    "events": {
      ".read": true,
      ".write": "auth != null"
    },
    
    // Polls - public read, authenticated write
    "polls": {
      ".read": true,
      ".write": "auth != null"
    },
    
    // Breaking News - public read, admin write
    "breakingNews": {
      ".read": true,
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },
    
    // Live Updates - public read, admin write
    "liveUpdates": {
      ".read": true,
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },

    // Trending Stories (auto-generated) - public read, admin write
    "trendingStories": {
      ".read": true,
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },

    // AI Picks (auto-generated) - public read, admin write
    "aiPicks": {
      ".read": true,
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },

    // Post analytics - public read, authenticated write
    "postAnalytics": {
      ".read": true,
      ".write": "auth != null"
    },

    // User interactions (for recommendations) - authenticated write
    "userInteractions": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth != null"
    },

    // Content reports - authenticated users can create one immutable report
    // per post; only admins can read reports or take moderation actions.
    "contentReports": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      "$contentId": {
        "$reporterId": {
          ".write": "auth != null && ((!data.exists() && auth.uid === $reporterId && newData.child('reporterId').val() === auth.uid && newData.child('contentId').val() === $contentId && newData.child('status').val() === 'pending') || root.child('users').child(auth.uid).child('role').val() === 'admin')",
          ".validate": "!newData.exists() || (newData.hasChildren(['contentId', 'contentType', 'reason', 'status', 'reporterId', 'createdAt', 'updatedAt']) && newData.child('contentId').val() === $contentId && newData.child('contentType').val() === 'post' && newData.child('reason').isString() && newData.child('reporterId').val() === $reporterId && newData.child('status').isString() && newData.child('createdAt').isString() && newData.child('updatedAt').isString())"
        }
      }
    },
    
    // News Roundups - public read, admin write
    "news-roundups": {
      ".read": true,
      "$roundupId": {
        ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
      }
    },

    // Leads - public submissions are written by Cloud Functions; admins manage them
    "leads": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },

    // Lead message templates - admin only
    "leadMessageTemplates": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },

    // Third-party integrations - admin only
    "integrations": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },

    // Lead notification logs - admin only, indexed for lead-specific lookups
    "leadNotificationLogs": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".indexOn": ["leadId"]
    },

    // Lead WhatsApp logs - admin only, indexed for lead-specific lookups
    "leadWhatsAppLogs": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".indexOn": ["leadId"]
    },
    
    // Analytics - admin only
    "analytics": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth != null"
    },
    
    // SOS - Blood Requests
    "bloodRequests": {
      ".read": true,
      ".write": "auth != null"
    },
    
    // Blood SOS - Emergency blood requests by city
    "blood-sos": {
      ".read": true,
      "$city": {
        ".write": "auth != null"
      }
    },
    
    // Bookmarks - users can access their own bookmarks
    "bookmarks": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "eventBookmarks": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "notificationPreferences": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "couponBrands": {
      ".read": true,
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },

    "brandsPublic": {
      ".read": true,
      ".write": false
    },

    "brandSlugs": {
      ".read": true,
      ".write": false
    },

    "couponCategories": {
      ".read": true,
      ".write": false
    },

    "brandAccounts": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      "$brandId": {
        ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || (root.child('users').child(auth.uid).child('role').val() === 'brand' && root.child('users').child(auth.uid).child('brandId').val() === $brandId && data.child('authUid').val() === auth.uid))",
        ".write": false
      }
    },

    "offers": {
      ".read": true,
      ".write": false,
      ".indexOn": ["brandId", "categoryId", "status", "endsAt"]
    },

    "brandRedemptionFeed": {
      "$brandId": {
        ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || (root.child('users').child(auth.uid).child('role').val() === 'brand' && root.child('users').child(auth.uid).child('brandId').val() === $brandId && root.child('brandAccounts').child($brandId).child('authUid').val() === auth.uid))",
        ".write": false,
        ".indexOn": ["offerId", "redeemedAt"]
      }
    },

    "offerClaimCountsByUser": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": false
      }
    },

    "couponRedemptions": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".write": false,
      ".indexOn": ["code", "brandId", "userId", "status"]
    },

    "couponClaimsByUser": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": false
      }
    },

    "userCoupons": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": false
      }
    },

    "couponAudit": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".write": false
    },

    "eventPayments": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".write": false
    },

    "registrationSecurity": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      "disposableDomains": {
        ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
      },
      "flaggedUsers": {
        "$uid": {
          ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
        }
      },
      "audit": { ".write": false },
      "rateLimits": { ".write": false }
    },
    
    // Likes - users can like content
    "likes": {
      ".read": true,
      "$postId": {
        "$uid": {
          ".write": "auth != null && auth.uid === $uid"
        }
      }
    },
    
    // Views/Analytics tracking
    "views": {
      ".read": true,
      ".write": true
    }
  }
}
